# Normalise line endings on checkout
* text=auto

# Shell scripts always LF
*.sh text eol=lf

# Sources
*.c text diff=cpp
*.cc text diff=cpp
*.cpp text diff=cpp
*.h text diff=cpp
*.hpp text diff=cpp
*.cmake text
CMakeLists.txt text

# Docs
*.md text

# Binary
*.png binary
*.jpg binary
*.ico binary
*.pdf binary
